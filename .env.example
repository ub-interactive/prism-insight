# .env.example

# ============================================
# MCP / LLM credentials (recommended)
# ============================================
# mcp_agent.config.yaml is tracked in-repo (no API keys inside). MCP Agent reads
# API keys from this file and/or OS environment (`OPENAI_API_KEY`, etc.).
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# FIRECRAWL_API_KEY=
# PERPLEXITY_API_KEY=
# Required by sec-edgar-mcp (identifies your HTTP client to Edgar):
# SEC_EDGAR_USER_AGENT=YourOrg (contact@yourdomain.example)

# Language Settings (Optional)
# Uncomment to set default language for reports and agents
# PRISM_LANGUAGE=en  # Option: en (English, default)

# Redis Streams (Optional - for trading signal pub/sub)
# Upstash Redis configuration (obtain from https://console.upstash.com)
# When configured, buy/sell signals will be published via Redis Streams.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token

# GCP Pub/Sub (Optional - for trading signal pub/sub)
# Google Cloud Pub/Sub configuration
# When configured, buy/sell signals will be published via GCP Pub/Sub.
# GCP_PROJECT_ID=your-project-id
# GCP_PUBSUB_TOPIC_ID=prism-trading-signals
# GCP_PUBSUB_SUBSCRIPTION_ID=prism-trading-signals-sub
# GCP_CREDENTIALS_PATH=/path/to/service-account-key.json

# Report Generation Settings (Optional)
# Enable parallel processing for faster report generation
# WARNING: Parallel mode may hit OpenAI API rate limits, especially with GPT-5.2 or higher models.
# Default is "false" (sequential mode) for rate limit safety.
# PRISM_PARALLEL_REPORT=false

# Trading Journal Settings (Optional)
# Enable AI-powered trading journal for retrospective analysis and learning.
# When enabled, the system records and analyzes completed trades,
# compresses old memories, and uses past experience for better decisions.
# Default is "false" (disabled) - set to "true" to enable.
# ENABLE_TRADING_JOURNAL=false

# ============================================
# ChatGPT OAuth Proxy (Optional - PR #224)
# ============================================
# Use ChatGPT Plus/Pro subscription instead of OpenAI API key.
# Requires one-time login: python -m cores.chatgpt_proxy.oauth_login
# PRISM_OPENAI_AUTH_MODE=chatgpt_oauth
# PRISM_CHATGPT_PROXY_PORT=18741

# ============================================
# US Stock Market Settings
# ============================================

# Optional structured social sentiment context for US stock news analysis
# ADANOS_API_KEY=your_adanos_api_key
# ADANOS_API_BASE_URL=https://api.adanos.org

# ============================================
# Firebase Bridge (Optional - PRISM-Mobile app)
# ============================================
# Push notifications and message metadata for the PRISM-Mobile companion app.
# Disabled by default. Set FIREBASE_BRIDGE_ENABLED=true to activate.
# Requires: firebase-admin package, Firebase service account JSON key.
#
# FIREBASE_BRIDGE_ENABLED=false
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
# PRISM_FCM_DEFAULT_LANG=en
