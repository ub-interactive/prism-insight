$schema: ../../schema/mcp-agent.config.schema.json

execution_engine: asyncio
logger:
  type: console
  level: info
  batch_size: 100
  flush_interval: 2
  max_queue_size: 2048
  http_endpoint:
  http_headers:
  http_timeout: 5

mcp:
  servers:
    webresearch:
      command: "npx"
      args: [ "-y", "@mzxrai/mcp-webresearch@latest" ]
      read_timeout_seconds: 120

    firecrawl:
        command: "npx"
        args: [ "-y", "firecrawl-mcp" ]
        env:
          FIRECRAWL_API_KEY: "example key"

    perplexity:
      command: "npx"
      args:
        [
          "-y",
          "@perplexity-ai/mcp-server"
        ]
      env:
        PERPLEXITY_API_KEY: "example key"

    sqlite:
      command: "uv"
      args:
        [
          "--directory",
          "sqlite",
          "run",
          "mcp-server-sqlite",
          "--db-path",
          "stock_tracking_db"
        ]

    time:
      command: "uvx"
      args:
        [
          "mcp-server-time"
        ]

    # ==========================================================================
    # US Stock Market Servers
    # ==========================================================================

    # Yahoo Finance MCP server for US stock data (PyPI: yahoo-finance-mcp)
    # Python-based, uses stable yfinance library (not deprecated yahoo-finance2)
    # Provides: OHLCV, company info, financials, institutional holders, news, recommendations
    yahoo_finance:
      command: "uvx"
      args: ["--from", "yahoo-finance-mcp", "yahoo-finance-mcp"]
      read_timeout_seconds: 120

    # SEC EDGAR MCP server for official SEC filings and financial data (PyPI: sec-edgar-mcp)
    # FREE - no API key required, just user agent for rate limiting
    # Provides: 10-K/10-Q/8-K filings, XBRL financials, insider trading
    sec_edgar:
      command: "uvx"
      args: ["--from", "sec-edgar-mcp", "sec-edgar-mcp"]
      env:
        SEC_EDGAR_USER_AGENT: "YourCompany (your-email@example.com)"
      read_timeout_seconds: 120

openai:
  # Secrets (API keys, etc.) are stored in an mcp_agent.secrets.yaml file which can be gitignored
  default_model: gpt-5.1
  reasoning_effort: high
  # Optional model overrides by workflow (keys used by cores/model_config.py)
  models:
    report_generation: gpt-5.4-mini
    us_journal: gpt-5.4-mini
    us_macro_analysis: gpt-5.4-mini
    us_report_filename: gpt-5.4-mini
    us_trading_decision: gpt-5.5
    us_sell_decision: gpt-5.5
    us_notification_summary: gpt-5.4-mini
    us_translation: gpt-5-nano
    archive_query_default: gpt-5.4-mini
    company_name_translation: gpt-5.4-mini
    example_dashboard_translation: gpt-5-nano
  archive_query_allowed_models:
    - gpt-5.4-mini
    - gpt-4.1-mini
    - gpt-4.1
    - gpt-4.1-nano
  # When set, overrides every bundled ChatGPT-proxy Codex map target (see chatgpt_proxy_model_map).
  # chatgpt_proxy_fallback_model: gpt-5.4-mini
  # Explicit per-alias overrides for Codex-compatible gateway:
  # chatgpt_proxy_model_map:
  #   gpt-4o: gpt-5.4-mini
  chatgpt_proxy_request_default_model: gpt-4o

anthropic:
  default_model: claude-sonnet-4-6
  models:
    firecrawl_analyst: claude-sonnet-4-6

# Optional: Spark model for firecrawl_client.firecrawl_agent (default spark-1-mini)
# firecrawl:
#   spark_agent_model: spark-1-pro

